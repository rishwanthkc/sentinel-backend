# Copy to .env for local dev (NEVER commit .env — it is gitignored).
# For local MySQL leave DB_CA_CERT empty. For Aiven, fill it in (see DEPLOY.md).

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=womens_db

# Managed-DB TLS certificate (Aiven "CA certificate"). Paste the full PEM.
# Leave empty for a local MySQL without SSL.
DB_CA_CERT=
